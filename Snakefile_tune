# Parse tune variant algo names into Hydra overrides that target a shared
# template in conf/algo/. Supported patterns:
#   deconfounder_r{R}_spatialplus_tune
#   deconfounder_r{R}_unet_tune
_DECONFOUNDER_TUNE_RE = re.compile(
    r"^deconfounder_r(\d+)_(spatialplus|unet)_tune$"
)

def algo_hydra_overrides(algo):
    m = _DECONFOUNDER_TUNE_RE.match(algo)
    if m:
        r, head = m.groups()
        template = f"deconfounder_{head}_tune"
        return (
            f"algo={template} "
            f"algo.name={algo} "
            f"algo.method.radius={r}"
        )
    return f"algo={algo}"


# make target files
targets = []
for t_type in ("disc", "cont"):
    envs = config["spaceenvs"][t_type]
    algos = config["algorithms"].get(t_type) or []
    for env in envs:
        for algo in algos:
            logfile = f"{config['logdir']}/{env}/{algo}_tune.parquet"
            targets.append(logfile)


# == Define rules ==
rule all:
    input:
        targets,


rule train_spaceenv:
    output:
        config["logdir"] + "/{spaceenv}/{algo}_tune.parquet",
    threads: config["concurrency"] * config["cpus_per_task"]
    resources:
        mem_mb=config["mem_mb"],
    params:
        concurrency=config["concurrency"],
        overwrite=config["overwrite"],
        algo_overrides=lambda w: algo_hydra_overrides(w.algo),
    log:
        err="logs/{spaceenv}/{algo}.err",
